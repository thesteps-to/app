{
  "name": "@thesteps/app",
  "version": "0.1.0",
  "description": "thesteps.to — guided plans for personal projects",
  "private": true,
  "type": "module",
  "workspaces": [
    "common",
    "client"
  ],
  "scripts": {
    "dev": "npm run dev -w @thesteps/client",
