    "typecheck": "npm run typecheck -w @thesteps/common && npm run typecheck -w @thesteps/client"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thesteps-to/app.git"
